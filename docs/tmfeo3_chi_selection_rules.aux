\newlabel{fig:fe_frames}{{2}{5}{\emph {Left}: Fe local frame arrows at each sublattice position. Red $=\hat {x}$, green $=\hat {y}$, blue $=\hat {z}$. Solid arrow: $\eta =+1$; dashed: $\eta =-1$. \emph {Right}: Summary table of Fe frame diagonal elements and their Bertaut patterns. The right-hand panel also lists the Bertaut inner products most relevant for the selection rules}{figure.caption.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \emph  {Left}: Tm local frame arrows. \emph  {Right}: Tm frame patterns and the detector coupling analysis. $\eta ^z_{\mathrm  {Tm}} = \sigma _C= (+,-,-,+)$, so $H\parallel c$ detects $M_z^{\mathrm  {Tm}}= c_2\,(\sigma _C\cdot \bm  {\lambda }^2_{\mathrm  {vec}})$. For this to be nonzero, $\lambda ^2$ must carry $\sigma _C$ pattern.}}{5}{figure.caption.4}\protected@file@percent }
\newlabel{fig:tm_frames}{{3}{5}{\emph {Left}: Tm local frame arrows. \emph {Right}: Tm frame patterns and the detector coupling analysis. $\etaz _{\mathrm {Tm}} = \sC = (+,-,-,+)$, so $H\parallel c$ detects $\Mz = c_2\,(\sC \cdot \vlam ^2_{\mathrm {vec}})$. For this to be nonzero, $\lamt $ must carry $\sC $ pattern}{figure.caption.4}{}}
